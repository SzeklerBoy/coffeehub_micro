APP_NAME=catalog-service
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=coffeehub_catalog
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=coffeehub_catalog
DB_USERNAME=root
DB_PASSWORD=

INTERNAL_API_SECRET=

# AWS S3 credentials for menu-item image storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
S3_BUCKET_NAME=

# URLs for peer services (used when catalog-service calls other services)
# AUTH_SERVICE_URL=http://auth-service:8000
# FACILITY_SERVICE_URL=http://facility-service:8000
# ORDER_SERVICE_URL=http://order-service:8000
