# ================================================================================
# ENVIRONMENT CONFIGURATION FOR LARAVEL GATEWAY APP
# ================================================================================
# Single source of truth: These values are defined in k8s/01-configmap.yml (public)
# and k8s/02-secret.yml (sensitive). Update those files, NOT this .env
# For local development, copy from k8s ConfigMap and Secret values below.
# ================================================================================

# APP CONFIGURATION
APP_NAME=CoffeeHub
APP_ENV=production
APP_KEY=base64:WbKzaJjsf2pxdpE1Ymcc/djhEOcCpP5BuOeMzbhIFtk=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# DATABASE CONFIGURATION
DB_CONNECTION=mysql
DB_HOST=cafe-db
DB_PORT=3306
DB_DATABASE=coffeehub
DB_USERNAME=cafe_user
DB_PASSWORD=cafe_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_FOREIGN_KEYS=true

# SECURITY
BCRYPT_ROUNDS=12

# LOGGING
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SESSION CONFIGURATION
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# FILE STORAGE
FILESYSTEM_DISK=local

# QUEUE & CACHE
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

# BROADCAST
BROADCAST_CONNECTION=pusher

# MEMCACHED
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# REDIS
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# MAIL CONFIGURATION
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=6c30ffcc541812
MAIL_PASSWORD=0bab7a140c0183
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=admin@coffeehub.com
MAIL_FROM_NAME=CoffeeHub

# AWS S3 CONFIGURATION
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=coffeehub-media
AWS_ENDPOINT_URL=http://localhost:4566
AWS_USE_PATH_STYLE_ENDPOINT=true

# STRIPE PAYMENT GATEWAY
STRIPE_KEY=
STRIPE_SECRET=

# PUSHER REAL-TIME
PUSHER_APP_ID=1854030
PUSHER_APP_KEY=b04d953911ef4b1d2807
PUSHER_APP_SECRET=1ee1e20362f794b35f73
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu

# VITE FRONTEND CONFIGURATION
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# MICROSERVICES URLS
MENU_SERVICE_URL=http://menu-app:8001/api
DESK_SERVICE_URL=http://desk-app:8002/api
ORDER_SERVICE_URL=http://order-app:8003/api
